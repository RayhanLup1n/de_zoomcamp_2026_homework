# This file specifies files that are *not* uploaded to Google Cloud Build.
# Only dashboard code, requirements, Dockerfile, and .streamlit config are needed.

.gcloudignore
.git
.gitignore

# Python cache
__pycache__/
*.pyc

# Local data (DuckDB - NOT needed for cloud, we use BigQuery)
data/

# GCP Credentials (should NOT be in the image)
*.json

# Infrastructure & pipeline code (not needed for dashboard deployment)
terraform/
dbt/
ingestion/
kestra/
scripts/
docker/
overviews/

# Documentation (not needed in image)
*.md
!dashboard/*.md

# Environment files
.env
.env.example

# Development files
.venv/
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/
deploy_simple.sh
