# Project Environment Variables

# Kestra UI Port
KESTRA_PORT=8080

# Streamlit Dashboard Port
DASHBOARD_PORT=8501

# DuckDB Database Path
DUCKDB_PATH=./data/capstone.duckdb

# Years to ingest (comma-separated)
YEARS=2024,2025

# Taxi types to ingest (comma-separated)
TAXI_TYPES=green,yellow

# NYC TLC Base URL
NYC_TLC_BASE_URL=https://nyc-tlc.s3.amazonaws.com/trip/data

# API Keys (if needed for future extensions)
# API_KEY=your_api_key_here
